# App
APP_ENV=local
APP_NAME=TravelAssistant
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend public values
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=TravelAssistant
NEXT_PUBLIC_MAP_PROVIDER=osm
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# Security
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Database and cache
DATABASE_URL=postgresql+psycopg://travelassistant:travelassistant@localhost:5432/travelassistant
REDIS_URL=redis://localhost:6379/0

# One-time production admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_ROLE=admin

# AI providers
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-nano
DEFAULT_STT_PROVIDER=openai
DEFAULT_TTS_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Voice
STT_MODEL=whisper-1
TTS_MODEL=tts-1
VOICE_NAME=alloy
VOICE_MAX_AUDIO_BYTES=10485760
VOICE_MAX_AUDIO_SECONDS=300

# Vector DB
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=travelassistant_chunks

# Optional external iVIVU JSONL import source
IVIVU_PROCESSED_DATA_PATH=

# Object storage
OBJECT_STORAGE_PROVIDER=r2
MEDIA_MAX_IMAGE_BYTES=5242880
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=travelassistant-media
R2_PUBLIC_BASE_URL=https://cdn.example.com

# Maps
MAP_PROVIDER=osm
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com

# Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
